# Server port
PORT=3003

# Database
MONGODB_URI=mongodb://localhost:27017/stock-trading

# Price Provider - MUST be set explicitly (no fallback)
# Options: ibkr, finnhub, alphavantage, simulator
# - ibkr: Uses Interactive Brokers TWS/Gateway (must be running)
# - finnhub: Uses Finnhub API (requires FINNHUB_API_KEY)
# - alphavantage: Uses Alpha Vantage API (requires ALPHA_VANTAGE_API_KEY)
# - simulator: Uses fake/mock prices for testing
PRICE_PROVIDER=ibkr

# Finnhub API Key (required if PRICE_PROVIDER=finnhub)
# Get free key at: https://finnhub.io/register
FINNHUB_API_KEY=

# Alpha Vantage API Key (required if PRICE_PROVIDER=alphavantage)
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# IBKR Settings (required if PRICE_PROVIDER=ibkr)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497      # 7497 = paper trading, 7496 = live trading
IBKR_CLIENT_ID=1    # Must be unique per connection

# Initial cash balance in USD
INITIAL_CASH=7000
